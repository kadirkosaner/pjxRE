:: dinerWork_event_sofiaChat {"position":"3200,3450","size":"200,100"}
<<silently>>
<<set $location = $activityOrigin || "dinerRubys">>
<<set _v = random(1, 3)>>
<</silently>>

<<if _v === 1>>
