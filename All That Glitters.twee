        category: "friendship",
        tier: 0,
        timeAdvance: 2,
        statGain: { friendship: 2 },
        variations: [
            [
                { from: "player", text: "Hey mom, how's your day going?" },
                { from: "character", text: "Pretty good sweetie, just finished cleaning the kitchen. How about you? Everything okay?" },
