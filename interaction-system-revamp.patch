+
+        <<if _isLevelStat && _stats[_levelKey] !== undefined>>
+            /* Level stat logic */
+            <<set _currentLevel = _stats[_levelKey]>>
+            <<set _maxLevel = (_charData.maxLevels && _charData.maxLevels[_statName] !== undefined) ? _charData.maxLevels[_statName] : 5>>
