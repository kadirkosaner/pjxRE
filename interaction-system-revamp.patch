+/* Max level config: $characters[charId].maxLevels[stat] — default 5 */
 <<widget "gainCharacterStat">><<nobr>>
     <<set _charId = $args[0]>>
     <<set _statName = $args[1]>>
@@ -401,7 +404,7 @@
 
     /* Safety checks */
