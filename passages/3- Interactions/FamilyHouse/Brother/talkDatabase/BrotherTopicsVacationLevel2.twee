/* ==========================================
   BROTHER TALK TOPICS — VACATION PHASE, LEVEL 2
   phase === "vacation" && friendshipLevel === 2

   VACATION L2 TONE:
   → He genuinely seeks you out — won't admit it but does
   → Opens up about future, identity, what he actually cares about
   → Dry humour as warmth: teases you = likes you
   → Backyard at night = his most honest version
   → Real sibling bond — rare but unmistakeable
   → Stat gains: friendship +3, trust +2, love +1-2

   8 CONTEXTS (same as L1):
   fhBrotherRoom_vacation_morning    _afternoon    _evening
   fhKitchen_vacation_morning        _evening
   fhLivingroom_vacation_morning     _afternoon    _evening
   fhBackyard_vacation_afternoon     _evening
========================================== */

<<set setup.brotherTopics.vacation.level2 = {

    /* ==========================================
       BROTHER'S ROOM — VACATION MORNING (L2)
    ========================================== */
    fhBrotherRoom_vacation_morning: {

        opening: [
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He's awake and he's been waiting for someone to walk past — you can tell by how quickly he calls out.<</narrative>>
<<dialog "brother">>(from his room) Hey. Come look at this.
(when you come in)
I've been working on this for two days. Tell me if it's good before I show anyone else.<</dialog>>
<<dialog "player">>(looking at his screen) Jake, this is actually really good.<</dialog>>
<<dialog "brother">>(with effort not to grin) It's rough. But thanks.
(already wanting to show you more)<</dialog>>`,
                friendship: 3, trust: 2
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He's been awake for a while and has made actual plans — a list on his desk.<</narrative>>
<<dialog "brother">>(showing you the list) Okay so I have things I want to do this vacation. Actually do.
(reading)
Finish a game I've been putting off. Draw something good. Try one new food — your suggestion, I'm open.
(looking at you)
What should the food be?<</dialog>>`,
                friendship: 3
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He says it like it costs him nothing — but it does, a little.<</narrative>>
<<dialog "brother">>I slept well last night. Good tired from actually doing stuff.
(to you, directly)
The backyard yesterday helped. Thanks for coming out.
(back to his desk)<</dialog>>`,
                friendship: 3, love: 1
            }
        ],

        design: [
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He's at his desk with his drawing stuff out among the gaming gear — not hiding it.<</narrative>>
<<dialog "brother">>(not looking up) I'm drawing. You can come in.
(a pause)
I'm working on a character design. For a game concept I have.
(showing you)
What do you think the colour palette should be?<</dialog>>`,
                friendship: 3, trust: 2
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He walks you through something he's made — actually walks you through it, explains his thinking.<</narrative>>
<<dialog "brother">>Okay so the idea is there are two worlds and the mechanic switches between them, and the visual language has to tell you which world you're in without text.
(pointing at his screen)
So I'm using warm versus cool. What do you think of this?<</dialog>>
<<dialog "player">>(looking) The warm one feels safer. That's interesting.<</dialog>>
<<dialog "brother">>(lighting up) That's exactly what I want.
(writing it down)
Okay. Good. That tells me I'm on the right track.<</dialog>>`,
                friendship: 3, trust: 2, love: 1
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He puts something in your hands — a small printed thing, a design he actually printed out.<</narrative>>
<<dialog "brother">>(braced) It's just a concept. It's not finished. Don't read into—<</dialog>>
<<dialog "player">>(looking at it) Jake. When did you get this good?<</dialog>>
<<dialog "brother">>(completely caught off guard) I— what?
(quietly)
You think it's good?<</dialog>>
<<dialog "player">>I think it's really good.<</dialog>>
<<dialog "brother">>(taking it back, processing)
...Okay. Cool. Thank you.<</dialog>>`,
                friendship: 3, trust: 2, love: 1
            }
        ],

        morning: [
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He asks you something out of nowhere, first thing:<</narrative>>
<<dialog "brother">>If you could live anywhere, where would you go?
(eating cereal at his desk, genuinely curious)<</dialog>>
<<dialog "player">>(thinking) Somewhere with seasons. Somewhere walkable.<</dialog>>
<<dialog "brother">>(nodding) Yeah. Me too, probably.
(a beat)
I'd want somewhere with good internet though. Non-negotiable.<</dialog>>`,
                friendship: 3
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He's already up, sitting with his sketchbook open and a cup of tea — grown up somehow, in the morning light.<</narrative>>
<<dialog "player">>(in the doorway) You look different this vacation.<</dialog>>
<<dialog "brother">>(not offended, thinking about it) I feel kind of different. I don't know. Easier.
(shrugging)
Maybe I needed the break more than I thought.<</dialog>>`,
                friendship: 3, trust: 1
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomMorning-" + random(1,3) + ".webp">>
<<image _img "100%">>
<<narrative>>He has two cups of tea ready when you come in.<</narrative>>
<<dialog "brother">>(handing you one) I figured.
(sitting back at his desk)
I've been up for a while.<</dialog>>
<<dialog "player">>What have you been doing?<</dialog>>
<<dialog "brother">>(a look at his screen — something creative, clearly) Stuff. It's going well.
(and that's all he'll say, but the energy is good)<</dialog>>`,
                friendship: 3, love: 1
            }
        ]
    },

    /* ==========================================
       BROTHER'S ROOM — VACATION AFTERNOON (L2)
    ========================================== */
    fhBrotherRoom_vacation_afternoon: {

        gaming: [
            {
text: `<<set _img = "assets/content/scenes/interactions/brother/vacation/level2/bedroomAfternoon-" + random(1,3) + ".webp">>
