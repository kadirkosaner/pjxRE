            {
text: `<<set _img = "assets/content/scenes/interactions/james/level1/jamesOnBreakAfternoon-1.webp">>
<<image _img "100%">>
<<narrative>>James is downing an entire glass of ice water in one go.<</narrative>>
<<dialog "dinerChef">>Lost about five pounds of sweat today. It's a furnace back here.<</dialog>>
<<dialog "player">>It looks intense.<</dialog>>
<<dialog "dinerChef">>It is. Stay in the front air conditioning as long as Vince lets you.<</dialog>`,
                friendship: 2, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/james/level1/jamesOnBreakAfternoon-2.webp">>
<<image _img "100%">>
<<narrative>>James points a greasy spatula at you menacingly.<</narrative>>
<<dialog "dinerChef">>If you see a table of eight coming in, you tell me before they sit down. Okay?<</dialog>>
<<dialog "player">>I'll try.<</dialog>>
<<dialog "dinerChef">>Don't try. Do. I need warning to prep the grill space.<</dialog>`,
                friendship: 1, trust: 0
