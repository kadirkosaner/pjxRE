            },
            {
text: `<<set _img = "assets/content/scenes/interactions/james/level1/jamesOnBreakMorning-2.webp">>
<<image _img "100%">>
<<narrative>>James is doing his own prep, ignoring you for the most part.<</narrative>>
<<dialog "player">>Pretty quiet morning.<</dialog>>
<<dialog "dinerChef">>Quiet is the calm before the lunch rush. Enjoy sitting down while you can.<</dialog>>
<<dialog "player">>You don't take breaks?<</dialog>>
<<dialog "dinerChef">>Kitchen never sleeps. Sit.<</dialog>`,
                friendship: 1, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/james/level1/jamesOnBreakMorning-3.webp">>
<<image _img "100%">>
<<narrative>>James yells towards the front of the house before looking at you.<</narrative>>
<<dialog "dinerChef">>Are they still out over there? Tell Emma to pick up her ticket.<</dialog>>
<<dialog "player">>I'm on break, actually.<</dialog>>
<<dialog "dinerChef">>Yeah, I can see that. I'm just venting. My eggs are getting cold. Typical.<</dialog>`,
                friendship: 1, trust: 0
            }
        ]
    },

    dinerRubys_workingOnBreak_afternoon: {

