text: `<<set _img = "assets/content/scenes/interactions/mike/level1/mikeCommonMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Mike nods his head to a beat only he can hear through his earbuds.<</narrative>>
<<dialog "dinerDishwasher">>You see Vince looking this way, tell me so I can hide the headphones.<</dialog>>
<<dialog "player">>He's busy in the front.<</dialog>>
<<dialog "dinerDishwasher">>Good. A man needs his tunes if he's gonna wash five hundred forks.<</dialog>>
<<dialog "player">>What are you listening to?<</dialog>>
<<dialog "dinerDishwasher">>Metal. It helps.<</dialog>`,
                friendship: 2, trust: 1
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/mike/level1/mikeCommonMorning-2.webp">>
<<image _img "100%">>
<<narrative>>Mike takes out an earbud as you walk up, looking annoyed for a second.<</narrative>>
<<dialog "dinerDishwasher">>Oh, it's you. Thought it was Sofia coming to dump more mugs.<</dialog>>
<<dialog "player">>Just me passing by.<</dialog>>
<<dialog "dinerDishwasher">>Cool. Back to it, then.<</dialog>`,
                friendship: 1, trust: 0
