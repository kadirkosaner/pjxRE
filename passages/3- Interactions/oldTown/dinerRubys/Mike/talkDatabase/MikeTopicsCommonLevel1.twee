            {
text: `<<set _img = "assets/content/scenes/interactions/mike/level1/mikeCommonMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Mike turns off the sprayer for a moment, wiping his wet hands on his apron.<</narrative>>
<<dialog "dinerDishwasher">>Loud out there today. I can hear the plates clinking from here.<</dialog>>
<<dialog "player">>It's a full house.<</dialog>>
<<dialog "dinerDishwasher">>Means a full sink for me. Better get back to it. Later.<</dialog>>
<<dialog "player">>Take it easy, Mike.<</dialog>>
<<dialog "dinerDishwasher">>Always.<</dialog>`,
                friendship: 1, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/mike/level1/mikeCommonMorning-2.webp">>
<<image _img "100%">>
<<narrative>>Mike has one earbud in, aggressively scrubbing a burnt pan.<</narrative>>
<<dialog "dinerDishwasher">>James burned the eggs again. Who burns eggs at 8 AM?<</dialog>>
<<dialog "player">>Must have been distracted.<</dialog>>
<<dialog "dinerDishwasher">>I'm the one paying the price. This crust is rock solid.<</dialog>>
<<dialog "player">>Hope it comes off.<</dialog>>
<<dialog "dinerDishwasher">>It will. I bring the muscle.<</dialog>`,
                friendship: 1, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/mike/level1/mikeCommonMorning-3.webp">>
<<image _img "100%">>
<<narrative>>Mike stares absently at the soapy water running down the drain.<</narrative>>
<<dialog "player">>You zone out a bit?<</dialog>>
<<dialog "dinerDishwasher">>Huh? Oh. Yeah. The sound of the water, man. It's hypnotic.<</dialog>>
<<dialog "player">>Better than the yelling.<</dialog>>
<<dialog "dinerDishwasher">>A million times better. Catch you later.<</dialog>`,
                friendship: 2, trust: 0
            }
        ],

