<<dialog "player">>See you on the flip side.<</dialog>>
<<dialog "charClerkTom">>Right on.<</dialog>`,
                friendship: 2, trust: 1
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneAfternoon-3.webp">>
<<image _img "100%">>
<<narrative>>Tom mock-salutes you from his station.<</narrative>>
