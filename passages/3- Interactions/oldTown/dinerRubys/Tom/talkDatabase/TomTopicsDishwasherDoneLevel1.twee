    dinerRubys_workingDone_morning: {

        first_shift_done: [
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Tom raises his coffee cup in a small toast as you walk by.<</narrative>>
<<dialog "charClerkTom">>Morning shift complete. Look at you, surviving the breakfast rush without throwing a spatula at anyone.<</dialog>>
<<dialog "player">>I don't even use a spatula.<</dialog>>
<<dialog "charClerkTom">>Doesn't matter, it's the thought that counts. Good job today.<</dialog>>
<<dialog "player">>Thanks, Tom.<</dialog>>
<<dialog "charClerkTom">>Go collapse now.<</dialog>`,
                friendship: 2, trust: 1
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneMorning-2.webp">>
<<image _img "100%">>
<<narrative>>Tom is holding an empty tray but stops you with a grin.<</narrative>>
<<dialog "charClerkTom">>All done for the day? I'm officially jealous.<</dialog>>
<<dialog "player">>I am officially exhausted.<</dialog>>
<<dialog "charClerkTom">>Go get an actual breakfast somewhere else. Let someone else wash your coffee cup for once.<</dialog>>
<<dialog "player">>Sounds like a plan.<</dialog>>
<<dialog "charClerkTom">>Don't think about dishes until tomorrow.<</dialog>`,
                friendship: 2, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneMorning-3.webp">>
<<image _img "100%">>
<<narrative>>Tom smiles broadly as he sees you packing up your stuff.<</narrative>>
<<dialog "charClerkTom">>You smell significantly less like sink water now that you're off the clock. It's a miracle.<</dialog>>
<<dialog "player">>Very funny.<</dialog>>
<<dialog "charClerkTom">>I try. Get out of here before Vince finds you an excuse to stay.<</dialog>>
<<dialog "player">>Heading out right now.<</dialog>>
<<dialog "charClerkTom">>Run free.<</dialog>`,
                friendship: 2, trust: 1
            }
        ],

        off_clock: [
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Tom claps a hand lightly on the counter as you pass.<</narrative>>
<<dialog "charClerkTom">>Leaving so soon? The fun is just starting.<</dialog>>
<<dialog "player">>You handle the fun without me.<</dialog>>
<<dialog "charClerkTom">>I will bravely carry on the diner torch. Enjoy your afternoon, try to stay out of trouble.<</dialog>>
<<dialog "player">>Trouble isn't on my schedule.<</dialog>>
<<dialog "charClerkTom">>That's the spirit.<</dialog>`,
                friendship: 1, trust: 0
