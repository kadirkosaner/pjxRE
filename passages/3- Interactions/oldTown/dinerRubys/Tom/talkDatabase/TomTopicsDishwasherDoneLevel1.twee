<<dialog "charClerkTom">>That's my guy. Have a great rest of your day.<</dialog>>
<<dialog "player">>Take care, Tom.<</dialog>>
<<dialog "charClerkTom">>Always.<</dialog>`,
                friendship: 2, trust: 1
            }
        ],

        relax: [
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneAfternoon-1.webp">>
<<image _img "100%">>
<<narrative>>Tom is resting briefly beside the cash register.<</narrative>>
