            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneMorning-2.webp">>
<<image _img "100%">>
<<narrative>>Tom points significantly at the exit door.<</narrative>>
<<dialog "charClerkTom">>That door right there... it leads to the outside world. Do you remember what it looks like?<</dialog>>
<<dialog "player">>I'm about to find out.<</dialog>>
<<dialog "charClerkTom">>Tell the sun I miss it.<</dialog>>
<<dialog "player">>I will.<</dialog>>
<<dialog "charClerkTom">>Appreciate it.<</dialog>`,
                friendship: 2, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneMorning-3.webp">>
<<image _img "100%">>
<<narrative>>Tom leans closely with a fake urgent expression.<</narrative>>
<<dialog "charClerkTom">>Quick, pretend you're a customer so I can practice my greeting without getting yelled at.<</dialog>>
<<dialog "player">>I don't have time for this.<</dialog>>
<<dialog "charClerkTom">>A tough customer! Even better. Fine, get out of here. Have a good one.<</dialog>>
<<dialog "player">>You too.<</dialog>>
<<dialog "charClerkTom">>See ya.<</dialog>`,
                friendship: 2, trust: 1
            }
        ],

        good_job: [
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomDoneMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Tom nods respectfully as you shoulder your bag.<</narrative>>
<<dialog "charClerkTom">>Not gonna lie, you hold your own back there better than anyone I've seen in a while.<</dialog>>
<<dialog "player">>Thanks, Tom. Means a lot.<</dialog>>
<<dialog "charClerkTom">>Don't let Vince know I compliment you, he thinks praise makes people soft. Good work today.<</dialog>>
<<dialog "player">>See you around.<</dialog>>
<<dialog "charClerkTom">>Catch you later.<</dialog>`,
                friendship: 2, trust: 1
