        dish_check: [
            {
text: `<<set _img = "assets/content/scenes/interactions/tom/level1/tomOnBreakMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Tom glances nervously toward the back kitchen.<</narrative>>
<<dialog "charClerkTom">>Are the prep plates caught up? James was throwing a fit about bowls earlier.<</dialog>>
<<dialog "player">>I scrubbed them all.<</dialog>>
<<dialog "charClerkTom">>You're a lifesaver. He yelled at me twice for not finding him a green bowl fast enough.<</dialog>>
