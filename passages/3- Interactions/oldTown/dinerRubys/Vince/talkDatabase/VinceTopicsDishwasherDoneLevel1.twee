<<set setup.vinceTopics.workingDone.level1 = {

    dinerRubys_workingDone_morning: {

        off_the_clock: [
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Vince steps away from the register, looking you up and down.<</narrative>>
<<dialog "dinerManager">>Ah, out of uniform already. You look different when you're not swimming in soap suds. Better.<</dialog>>
<<dialog "player">>Thanks, headed home.<</dialog>>
<<dialog "dinerManager">>A shame to head home so early on a beautiful day. The outside world is waiting.<</dialog>>
<<dialog "player">>I need sleep.<</dialog>>
<<dialog "dinerManager">>Sleep is overrated. Take care out there.<</dialog>`,
                friendship: 1, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-2.webp">>
<<image _img "100%">>
<<narrative>>Vince leans back, folding his arms loosely across his chest.<</narrative>>
<<dialog "dinerManager">>Punching out exactly on the minute. Efficient. I admire efficiency, but I also admire dedication.<</dialog>>
<<dialog "player">>I worked my full shift.<</dialog>>
<<dialog "dinerManager">>You did. Flawlessly. But those who stay a little later often find themselves rewarded... eventually.<</dialog>>
<<dialog "player">>Maybe next time.<</dialog>>
<<dialog "dinerManager">>_(smiles tightly)_ I'll remember you said that.<</dialog>`,
                friendship: 1, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-3.webp">>
<<image _img "100%">>
<<narrative>>Vince checks his clipboard before putting it down dramatically.<</narrative>>
<<dialog "dinerManager">>Off the clock. You're officially a civilian again. Do you feel the sudden rush of freedom?<</dialog>>
<<dialog "player">>I feel the rush of needing my bed.<</dialog>>
<<dialog "dinerManager">>Youth is wasted on the tired. Go home, wash the smell of grease out of your skin. It sticks, you know.<</dialog>>
<<dialog "player">>I'm aware.<</dialog>>
<<dialog "dinerManager">>Don't scrub too hard. Just hard enough.<</dialog>`,
                friendship: 2, trust: 1
            }
        ],

        good_worker: [
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Vince places a hand on the doorframe as you pass by into the front.<</narrative>>
<<dialog "dinerManager">>You were extremely quiet today. Just hands in the sink, head down. I appreciate a silent worker.<</dialog>>
<<dialog "player">>I just focus on the job.<</dialog>>
<<dialog "dinerManager">>A beautiful trait. Some of my girls talk too much. Quiet people have better secrets.<</dialog>>
<<dialog "player">>I'm just boring.<</dialog>>
<<dialog "dinerManager">>_(chuckles darkly)_ We'll see about that.<</dialog>`,
                friendship: 2, trust: 1
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-2.webp">>
<<image _img "100%">>
<<narrative>>Vince smooths down the collar of his shirt while looking at you.<</narrative>>
<<dialog "dinerManager">>You're proving to be one of my better hires. You don't ask annoying questions. You follow orders.<</dialog>>
<<dialog "player">>It's an easy job.<</dialog>>
<<dialog "dinerManager">>Only because you make it look easy. I like things that are easy. They don't cause me headaches.<</dialog>>
<<dialog "player">>Glad to help.<</dialog>>
<<dialog "dinerManager">>Be safe walking back.<</dialog>`,
                friendship: 2, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-3.webp">>
<<image _img "100%">>
<<narrative>>Vince nods respectfully at you, but his eyes linger.<</narrative>>
<<dialog "dinerManager">>You did a solid job today. You wiped the counters perfectly. Spotless.<</dialog>>
<<dialog "player">>Just doing my part.<</dialog>>
<<dialog "dinerManager">>Your part is very valuable to me. I like keeping valuable things close. Have a good afternoon.<</dialog>>
<<dialog "player">>You too.<</dialog>>
<<dialog "dinerManager">>I intend to.<</dialog>`,
                friendship: 2, trust: 1
            }
        ],

        stay_awhile: [
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-1.webp">>
<<image _img "100%">>
<<narrative>>Vince gestures to an empty booth near his office.<</narrative>>
<<dialog "dinerManager">>You don't have to sprint out the door. You're allowed to sit in a booth and decompress. I encourage it.<</dialog>>
<<dialog "player">>I prefer to decompress at home.<</dialog>>
<<dialog "dinerManager">>Home is lonely. Here, you're among friends. I'd bring you a coffee myself.<</dialog>>
<<dialog "player">>I really have to go.<</dialog>>
<<dialog "dinerManager">>Suit yourself. But the offer stands.<</dialog>`,
                friendship: 2, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-2.webp">>
<<image _img "100%">>
<<narrative>>Vince stops you softly by standing in your direct path.<</narrative>>
<<dialog "dinerManager">>The morning rush is over. Why don't you stick around? I'm doing payroll, we could... chat.<</dialog>>
<<dialog "player">>I wouldn't want to distract you from your numbers.<</dialog>>
<<dialog "dinerManager">>You wouldn't be a distraction. You'd be... an enhancement. But if you must leave, I won't stop you.<</dialog>>
<<dialog "player">>Okay, bye.<</dialog>>
<<dialog "dinerManager">>_(steps aside with a slow smile)_ Goodbye.<</dialog>`,
                friendship: 1, trust: 0
            },
            {
text: `<<set _img = "assets/content/scenes/interactions/vince/level1/vinceDoneMorning-3.webp">>
<<image _img "100%">>
<<narrative>>Vince taps his pen on the counter in a slow rhythm.<</narrative>>
<<dialog "dinerManager">>You know, if you stayed off the clock for another hour, I could show you how the inventory system works.<</dialog>>
<<dialog "player">>I'm not aiming for management.<</dialog>>
<<dialog "dinerManager">>Everyone should aim to be managed. Or to manage. It's a very intimate dynamic. Learning it is useful.<</dialog>>
<<dialog "player">>I'll pass today.<</dialog>>
<<dialog "dinerManager">>A missed opportunity.<</dialog>`,
                friendship: 2, trust: 1
            }
        ]
