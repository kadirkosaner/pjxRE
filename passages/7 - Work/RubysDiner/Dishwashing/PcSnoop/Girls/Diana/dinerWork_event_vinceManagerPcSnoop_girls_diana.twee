        <span class="link-internal btn-style locked btn-secondary" data-tooltip="No time left"><span class="icon icon-lock icon-12"></span> Clip 04 — Aug 29</span>
    <</if>>
<</if>>
<<if !$jobState.vincePcSnoopSeenDianaVideos.v5>>
    <<if $jobState.vincePcSnoopTimeLeftMin >= _dianaVideoCostV5>>
        <<btn "Clip 05 — Aug 25" "dinerWork_event_vinceManagerPcSnoop_girls_diana_video5" "secondary">><</btn>>
